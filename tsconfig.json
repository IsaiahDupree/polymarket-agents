{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./apps/web/src/*", "./src/*"],
      "@core/*": ["./packages/core/src/*"],
      "@adapters/polymarket/*": ["./packages/adapters/polymarket/src/*"],
      "@adapters/coinbase/*": ["./packages/adapters/coinbase/src/*"],
      "@adapters/aave/*": ["./packages/adapters/aave/src/*"],
      "@adapters/sim/*": ["./packages/adapters/sim/src/*"],
      "@strategy/*": ["./packages/strategy/src/*"],
      "@risk/*": ["./packages/risk/src/*"],
      "@oms/*": ["./packages/oms/src/*"],
      "@data/*": ["./packages/data/src/*"],
      "@quant/*": ["./packages/quant/src/*"],
      "@wallet/*": ["./packages/wallet/src/*"],
      "@agent/*": ["./packages/agent/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "apps/web/next-env.d.ts",
    "apps/web/.next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "scripts", "tests", "**/node_modules", "**/.next", "**/dist"]
}
