# Copy to .env.local and fill in.
# .env.local is gitignored — never commit real keys.

# --- Polymarket Relayer ---
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=

# --- Wallet signer (for L1 CLOB auth + order signing) ---
# Private key for the signer address above. Required to derive L2 CLOB credentials.
POLYMARKET_PRIVATE_KEY=

# --- CLOB L2 credentials (auto-derived; populate via `npm run derive:creds`) ---
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASSPHRASE=

# --- Trading wallet ---
# For new API users this is the deposit-wallet (POLY_1271); for legacy users it's their proxy/safe address.
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1  # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271

# --- Hosts ---
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_RELAYER_HOST=https://relayer-v2.polymarket.com
POLYMARKET_CHAIN_ID=137
