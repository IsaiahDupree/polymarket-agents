# Copy to .env.local and fill in.
# .env.local is gitignored — never commit real keys.

# --- Polymarket Relayer ---
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=

# --- Wallet signer (for L1 CLOB auth + order signing) ---
# Private key for the signer address above. Required to derive L2 CLOB credentials.
POLYMARKET_PRIVATE_KEY=

# --- CLOB L2 credentials (auto-derived; populate via `npm run derive:creds`) ---
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASSPHRASE=

# --- Trading wallet ---
# For new API users this is the deposit-wallet (POLY_1271); for legacy users it's their proxy/safe address.
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1  # 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271

# --- Hosts ---
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_RELAYER_HOST=https://relayer-v2.polymarket.com
POLYMARKET_CHAIN_ID=137

# --- Coinbase Advanced Trade (CDP key, JWT auth) ---
# Two ways to provide the CDP API key — use ONE:
#  (a) point to a JSON file: { "name": "organizations/.../apiKeys/...", "privateKey": "-----BEGIN EC PRIVATE KEY-----\n..." }
COINBASE_CDP_KEY_FILE=coinbase_cloud_api_key.json
#  (b) or inline as env vars (private key newlines may be literal `\n`):
# COINBASE_CDP_KEY_NAME=
# COINBASE_CDP_PRIVATE_KEY=

# Optional host override (e.g., for sandbox: https://api-sandbox.coinbase.com)
COINBASE_HOST=https://api.coinbase.com

# Coinbase trading safety gates — separate from Polymarket's so enabling one
# doesn't silently arm the other. Defaults are conservative.
COINBASE_ALLOW_TRADE=0        # set to 1 to permit live order placement
COINBASE_MAX_TRADE_USD=25     # per-trade cap (BUYs use quote_size; SELLs estimated against best bid)
COINBASE_MAX_DAILY_USD=100    # rolling 24h cap, summed from evolution_log

# Endpoint-sweep destructive controls
COINBASE_SWEEP_PRODUCT=BTC-USD   # which product to exercise in the sweep
COINBASE_SWEEP_MAX_USD=0         # dollar size for a real LIVE sweep order; 0 keeps it preview-only

# --- CoinDesk Data API (historical 1-min OHLCV back to coin origination) ---
# Get a key at https://developers.coindesk.com/. Used to backfill years of
# 1-min candles into coindesk_candles for richer arena strategy backtests.
COINDESK_API_KEY=
COINDESK_HOST=https://data-api.coindesk.com

# API auth (audit F1, 2026-05-25). Set to a strong random secret in prod.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mutating /api/** routes (POST/PUT/PATCH/DELETE) require Authorization: Bearer $ARENA_API_TOKEN.
ARENA_API_TOKEN=

# Dev shortcut: set to 1 to bypass auth on localhost. NEVER set in production.
NEXT_PUBLIC_ALLOW_UNAUTHED_LOCAL=1
